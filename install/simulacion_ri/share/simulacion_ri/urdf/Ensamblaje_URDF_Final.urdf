<?xml version="1.0" encoding="utf-8"?>
<robot name="Ensamblaje_URDF_Final">
  <link name="base_link">
    <inertial>
      <origin xyz="-0.021385397291191 5.25169810653347E-06 0.0469766803177353" rpy="0 0 0" />
      <mass value="1.61129016278306" />
      <inertia ixx="0.00729579790366393" ixy="-1.00730993267901E-08" ixz="4.04800061291069E-05" iyy="0.0102401657963008" iyz="1.18114222568118E-08" izz="0.0171542213638773" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://simulacion_ri/meshes/base_link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://simulacion_ri/meshes/base_link.STL" />
      </geometry>
    </collision>
  </link>

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_footprint"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="rueda_delante_izquierda_link">
    <inertial>
      <origin xyz="4.4236E-09 -0.011457 -1.8099E-08" rpy="0 0 0" />
      <mass value="0.16695" />
      <inertia ixx="6.7293E-05" ixy="-7.7682E-13" ixz="-1.0817E-09" iyy="0.00011321" iyz="3.1219E-12" izz="6.7296E-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://simulacion_ri/meshes/rueda_delante_izquierda_link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://simulacion_ri/meshes/rueda_delante_izquierda_link.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="rueda_delante_izquierda_joint" type="continuous">
    <origin xyz="0.090125 0.14065 0.0125" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="rueda_delante_izquierda_link" />
    <axis xyz="0 1 0" />
    <dynamics damping="0.1" friction="0.1"/>
    <limit effort="10" velocity="18.85" />
  </joint>

  <link name="rueda_delante_derecha_link">
    <inertial>
      <origin xyz="-1.8593E-08 0.011457 -1.3155E-09" rpy="0 0 0" />
      <mass value="0.16695" />
      <inertia ixx="6.7296E-05" ixy="-3.2303E-12" ixz="5.9539E-12" iyy="0.00011321" iyz="-2.4005E-13" izz="6.7293E-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://simulacion_ri/meshes/rueda_delante_derecha_link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://simulacion_ri/meshes/rueda_delante_derecha_link.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="rueda_delante_derecha_joint" type="continuous">
    <origin xyz="0.090125 -0.14075 0.0125" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="rueda_delante_derecha_link" />
    <axis xyz="0 1 0" />
    <dynamics damping="0.1" friction="0.1"/>
    <limit effort="10" velocity="18.85" />
  </joint>

  <link name="rueda_trasera_izquierda_link">
    <inertial>
      <origin xyz="-1.5737E-08 -0.011457 -9.9717E-09" rpy="0 0 0" />
      <mass value="0.16695" />
      <inertia ixx="6.7295E-05" ixy="2.6991E-12" ixz="1.7823E-09" iyy="0.00011321" iyz="1.7238E-12" izz="6.7294E-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://simulacion_ri/meshes/rueda_trasera_izquierda_link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://simulacion_ri/meshes/rueda_trasera_izquierda_link.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="rueda_trasera_izquierda_joint" type="continuous">
    <origin xyz="-0.10111 0.14075 0.0125" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="rueda_trasera_izquierda_link" />
    <axis xyz="0 1 0" />
    <dynamics damping="0.1" friction="0.1"/>
    <limit effort="10" velocity="18.85" />
  </joint>

  <link name="rueda_trasera_derecha_link">
    <inertial>
      <origin xyz="-1.8576E-08 0.011457 -1.4516E-09" rpy="0 0 0" />
      <mass value="0.16695" />
      <inertia ixx="6.7296E-05" ixy="-3.198E-12" ixz="3.2541E-11" iyy="0.00011321" iyz="-2.4683E-13" izz="6.7293E-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://simulacion_ri/meshes/rueda_trasera_derecha_link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://simulacion_ri/meshes/rueda_trasera_derecha_link.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="rueda_trasera_derecha_joint" type="continuous">
    <origin xyz="-0.10111 -0.14075 0.0125" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="rueda_trasera_derecha_link" />
    <axis xyz="0 1 0" />
    <dynamics damping="0.1" friction="0.1"/>
    <limit effort="10" velocity="18.85" />
  </joint>

  <link name="lidar_link">
    <inertial>
      <origin xyz="0.0051275 0.00059155 -0.019551" rpy="0 0 0" />
      <mass value="0.14165" />
      <inertia ixx="5.691E-05" ixy="-2.879E-07" ixz="1.2475E-05" iyy="8.9322E-05" iyz="-7.2186E-07" izz="0.0001087" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://simulacion_ri/meshes/lidar_link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.21176 0.21176 0.20392 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://simulacion_ri/meshes/lidar_link.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="lidar_joint" type="fixed">
    <origin xyz="-0.0539 -3.5032E-05 0.17" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="lidar_link" />
    <axis xyz="0 0 0" />
  </joint>

  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>rueda_delante_izquierda_joint</left_joint>
      <left_joint>rueda_trasera_izquierda_joint</left_joint>
      <right_joint>rueda_delante_derecha_joint</right_joint>
      <right_joint>rueda_trasera_derecha_joint</right_joint>
      <wheel_separation>0.2814</wheel_separation>
      <wheel_radius>0.0325</wheel_radius>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <odom_publish_frequency>20</odom_publish_frequency>
      <covariance_x>0.001</covariance_x>
      <covariance_y>0.001</covariance_y>
      <covariance_yaw>0.001</covariance_yaw>
      <publish_odom_tf>true</publish_odom_tf>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
    </plugin>

    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
  </gazebo>

  <gazebo reference="lidar_link">
    <sensor name="lidar" type="gpu_lidar">
      <pose>0 0 0 0 0 0</pose>
      <topic>scan</topic>
      <update_rate>10</update_rate>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>
      <always_on>1</always_on>
      <visualize>true</visualize>
      <frame_id>lidar_link</frame_id>
    </sensor>
  </gazebo>
</robot>